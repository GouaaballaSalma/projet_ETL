  <step>
    <name>VALIDER_DATES</name>
    <type>ScriptValueMod</type>
    <description>Valide B11_STR et B19_STR - met a null si date invalide</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>VALIDER_DATES</jsScript_name>
        <jsScript_script>
var b11 = B11_STR;

if (b11 != null &amp;&amp; b11.trim().length == 8 &amp;&amp; b11.trim().match(/^[0-9]{8}$/)) {
  var s11 = b11.trim();
  var annee = parseInt(s11.substring(0, 4), 10);
  var mois  = parseInt(s11.substring(4, 6), 10);
  var jour  = parseInt(s11.substring(6, 8), 10);

  if (annee &lt; 1900 || mois &lt; 1 || mois > 12 || jour &lt; 1 || jour > 31) {
    B11_STR = null;
  }
} else {
  B11_STR = null;
}

var b19 = B19_STR;
if (b19 != null &amp;&amp; b19.trim().length == 8 &amp;&amp; b19.trim().match(/^[0-9]{8}$/)) {
  var s19 = b19.trim();
  var annee2 = parseInt(s19.substring(0, 4), 10);
  var mois2  = parseInt(s19.substring(4, 6), 10);
  var jour2  = parseInt(s19.substring(6, 8), 10);

  if (annee2 &lt; 1900 || mois2 &lt; 1 || mois2 > 12 || jour2 &lt; 1 || jour2 > 31) {
    B19_STR = null;
  }
} else {
  B19_STR = null;
}
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field>
        <name>B11_STR</name>
        <rename>B11_STR</rename>
        <type>String</type>
        <length>-1</length>
        <precision>-1</precision>
        <replace>Y</replace>
      </field>
      <field>
