  <step>
    <name>VALIDER_DATES_ET_MONTANTS</name>
    <type>ScriptValueMod</type>
    <description>Validation des dates vides et division par 100 des montants</description>
    <distribute>Y</distribute>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <compatible>N</compatible>
    <optimizationLevel>9</optimizationLevel>
    <jsScripts>
      <jsScript>
        <jsScript_type>0</jsScript_type>
        <jsScript_name>VALIDER_DATES</jsScript_name>
        <jsScript_script>
// Fonction pour valider et nettoyer les dates (certaines peuvent etre vides en BAM)
function validerDate(d_str) {
  if (d_str != null &amp;&amp; d_str.trim().length == 8 &amp;&amp; d_str.trim().match(/^[0-9]{8}$/)) {
    var annee = parseInt(d_str.substring(0, 4), 10);
    var mois  = parseInt(d_str.substring(4, 6), 10);
    var jour  = parseInt(d_str.substring(6, 8), 10);
    if (annee &lt; 1900 || mois &lt; 1 || mois > 12 || jour &lt; 1 || jour > 31) {
      return null;
    }
    return d_str.trim();
  }
  return null;
}

X09_STR = validerDate(X09_STR);
X10_STR = validerDate(X10_STR);
X11_STR = validerDate(X11_STR);
X14_STR = validerDate(X14_STR);

// Transformation des montants (Division par 100)
var X06 = null;
if (X06_CENTIMES_STR != null &amp;&amp; X06_CENTIMES_STR.trim().length > 0) {
  X06 = parseFloat(X06_CENTIMES_STR.trim()) / 100;
}

var X12 = null;
if (X12_CENTIMES_STR != null &amp;&amp; X12_CENTIMES_STR.trim().length > 0) {
  X12 = parseFloat(X12_CENTIMES_STR.trim()) / 100;
}
        </jsScript_script>
      </jsScript>
    </jsScripts>
    <fields>
      <field><name>X09_STR</name><rename>X09_STR</rename><type>String</type><length>-1</length><precision>-1</precision><replace>Y</replace></field>
      <field><name>X10_STR</name><rename>X10_STR</rename><type>String</type><length>-1</length><precision>-1</precision><replace>Y</replace></field>
      <field><name>X11_STR</name><rename>X11_STR</rename><type>String</type><length>-1</length><precision>-1</precision><replace>Y</replace></field>
